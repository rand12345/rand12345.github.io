---
interface Props {
  title: string;
  tagline: string;
  description: string;
  tags: string[];
  github?: string;
  stars?: number;
  comingSoon?: boolean;
  label?: string;
}

const { title, tagline, description, tags, github, stars, comingSoon, label } = Astro.props;
---

<article class="card p-6 flex flex-col gap-4 hover:border-zinc-700 transition-colors">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-lg font-semibold text-zinc-100">{title}</h3>
      <p class="text-accent font-mono text-xs mt-1">{tagline}</p>
    </div>
    {stars && (
      <span class="flex items-center gap-1 text-xs text-zinc-500 font-mono shrink-0">
        <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        {stars}
      </span>
    )}
  </div>

  <p class="text-zinc-400 text-sm leading-relaxed flex-1">{description}</p>

  <div class="flex flex-wrap gap-1.5">
    {tags.map(tag => (
      <span class="px-2 py-0.5 bg-zinc-800 rounded text-xs font-mono text-zinc-400">{tag}</span>
    ))}
  </div>

  <div class="flex items-center gap-3 pt-2 border-t border-zinc-800">
    {github ? (
      <a
        href={github}
        target="_blank"
        rel="noopener"
        class="flex items-center gap-1.5 text-xs text-zinc-400 hover:text-accent transition-colors font-mono"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
    ) : comingSoon ? (
      <span class="text-xs text-zinc-600 font-mono italic">
        {label ?? 'private — releasing soon'}
      </span>
    ) : (
      <span class="text-xs text-zinc-600 font-mono italic">
        {label ?? 'private — available on request'}
      </span>
    )}
  </div>
</article>
