---
const skills = [
  'Rust', 'Embassy-rs', 'RTIC', 'no_std',
  'C/C++', 'STM32', 'ESP32', 'BeagleBone',
  'CAN bus', 'RS485', 'I²C / SPI', 'Svelte', 'Python',
];
---

<section class="bg-circuit relative overflow-hidden">
  <!-- Decorative circuit trace SVG -->
  <div class="absolute inset-0 opacity-20 pointer-events-none" aria-hidden="true">
    <svg class="absolute bottom-0 right-0 w-96 h-96 text-accent" viewBox="0 0 200 200" fill="none">
      <path d="M180 20 L180 80 L120 80 L120 140 L60 140 L60 180" stroke="currentColor" stroke-width="1" stroke-dasharray="4 4"/>
      <circle cx="180" cy="20" r="4" fill="currentColor"/>
      <circle cx="120" cy="80" r="3" fill="currentColor"/>
      <circle cx="60" cy="140" r="3" fill="currentColor"/>
      <path d="M20 160 L80 160 L80 100 L140 100 L140 40" stroke="currentColor" stroke-width="1" opacity="0.5"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-24 sm:py-32 relative">
    <div class="max-w-3xl">
      <!-- Logo mark -->
      <p class="font-mono text-accent text-sm mb-6 tracking-widest uppercase">Open source · Embedded systems</p>

      <h1 class="text-4xl sm:text-5xl font-bold text-zinc-100 leading-tight mb-6">
        EV batteries.<br />
        <span class="text-accent">Vehicle-to-Home.</span><br />
        Renewable energy integration.
      </h1>

      <p class="text-zinc-400 text-lg leading-relaxed mb-10 max-w-2xl">
        Embedded Rust engineer working on open-source tooling for EV battery repurposing,
        bidirectional charging, solar inverter integration, and high-voltage cell management.
        Protocols: CAN, RS485, CHAdeMO, Modbus.
      </p>

      <div class="flex flex-wrap gap-4 mb-12">
        <a href="https://github.com/rand12345" target="_blank" rel="noopener" class="btn-primary">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a href="https://hvdc.dev" target="_blank" rel="noopener" class="btn-secondary">
          hvdc.dev →
        </a>
        <a href="https://crates.io/users/rand12345" target="_blank" rel="noopener" class="btn-secondary">
          crates.io
        </a>
      </div>

      <!-- Skill badges -->
      <div class="flex flex-wrap gap-2">
        {skills.map(skill => (
          <span class="px-3 py-1 bg-zinc-900 border border-zinc-800 rounded-full text-xs font-mono text-zinc-400">
            {skill}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
