---
interface Props {
  title: string;
  description: string;
  tags: string[];
  github?: string;
  cratesio?: string;
  stars?: number;
  forks?: number;
}

const { title, description, tags, github, cratesio, stars, forks } = Astro.props;
---

<article class="card p-5 flex flex-col gap-3 hover:border-zinc-700 transition-colors">
  <div class="flex items-start justify-between gap-2">
    <h3 class="text-sm font-semibold text-zinc-100 font-mono">{title}</h3>
    <div class="flex items-center gap-2 shrink-0">
      {stars && (
        <span class="flex items-center gap-1 text-xs text-zinc-500">
          <svg class="w-3 h-3 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          {stars}
        </span>
      )}
      {forks && (
        <span class="flex items-center gap-1 text-xs text-zinc-500">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16">
            <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"/>
          </svg>
          {forks}
        </span>
      )}
    </div>
  </div>

  <p class="text-zinc-400 text-xs leading-relaxed flex-1">{description}</p>

  <div class="flex flex-wrap gap-1">
    {tags.map(tag => (
      <span class="px-1.5 py-0.5 bg-zinc-800 rounded text-xs font-mono text-zinc-500">{tag}</span>
    ))}
  </div>

  <div class="flex items-center gap-3 pt-2 border-t border-zinc-800">
    {github && (
      <a href={github} target="_blank" rel="noopener" class="text-xs text-zinc-500 hover:text-accent transition-colors font-mono">
        GitHub ↗
      </a>
    )}
    {cratesio && (
      <a href={cratesio} target="_blank" rel="noopener" class="text-xs text-zinc-500 hover:text-accent transition-colors font-mono">
        crates.io ↗
      </a>
    )}
  </div>
</article>
